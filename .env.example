PORT=4000

# یک رشته‌ی تصادفی و طولانی بساز (مثلاً با: openssl rand -hex 32)
JWT_SECRET=یک-رشته-تصادفی-طولانی-اینجا-بگذار

# از پنل زرین‌پال (zarinpal.com) پس از ثبت‌نام پذیرنده دریافت می‌شود
ZARINPAL_MERCHANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# آدرس همین بک‌اند پس از دیپلوی (برای بازگشت از درگاه زرین‌پال)
CALLBACK_URL=https://your-backend.onrender.com/payment/callback

# آدرس سایت فروشگاه (دامنه‌ی خودت)
FRONTEND_URL=https://jordangalleryshop.com
